<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DameTab — Encontrá la tablatura</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Rubik+Mono+One&family=Space+Grotesk:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="style.css">

  <link rel="manifest" href="manifest.json">
  <meta name="theme-color" content="#0D0D0D">
  <!-- Iconos embebidos en base64: no dependen de archivos externos que puedan faltar -->
<link rel="icon" type="image/png" href="data:image/png;base64,">
<link rel="apple-touch-icon" href="data:image/png;base64,">

<!-- Configuración para PWA e iOS -->
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">

  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="DameTab">
</head>
<body>
  <div class="fondo-textura"></div>

  <main>
    <header class="hero">
      <p class="eyebrow">escuchá — identificá — tocá</p>
      <h1>DAME<span class="tab-resaltado">TAB</span></h1>
      <p class="subtitulo">Grabá unos segundos de cualquier canción y te encuentro los acordes para tocarla ahora mismo</p>
    </header>

    <section class="panel-grabacion">
      <div class="boton-envoltorio">
        <span id="ondas" class="ondas oculto" aria-hidden="true">
          <span></span><span></span><span></span>
        </span>
        <button id="btnGrabar" aria-label="Escuchar canción">
          <span class="icono-mic">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 15a3 3 0 003-3V6a3 3 0 10-6 0v6a3 3 0 003 3z" stroke="currentColor" stroke-width="1.6"/>
              <path d="M19 11a7 7 0 01-14 0M12 18v3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
            </svg>
          </span>
          <span id="btnTexto">Escuchar</span>
        </button>
      </div>

      <div id="visualizador" class="visualizador oculto" aria-hidden="true">
        <span></span><span></span><span></span><span></span><span></span><span></span><span></span>
      </div>

      <div id="vinilo" class="vinilo oculto" aria-hidden="true">
        <div class="vinilo-disco">
          <div class="vinilo-surco"></div>
          <div class="vinilo-surco"></div>
          <div class="vinilo-centro"></div>
        </div>
      </div>

      <p id="estado" class="estado"></p>
    </section>

    <section id="resultado" class="resultado oculto">
      <div class="resultado-header">
        <img id="portadaAlbum" class="portada-album oculto" alt="Portada del álbum">
        <p class="eyebrow">encontré</p>
        <h2 id="cancionTitulo"></h2>
        <p id="cancionArtista" class="cancion-artista"></p>
      </div>

      <p class="aclaracion">Las cuerdas indican qué tan confiable pinta la fuente — no es un rating de otros usuarios</p>

      <div id="listaOpciones" class="lista-opciones"></div>

      <button id="btnNuevaBusqueda" class="boton-nueva-busqueda">↺ Nueva búsqueda</button>
    </section>
  </main>

  <script src="app.js"></script>
</body>
</html>
